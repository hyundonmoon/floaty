{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/tauri-v2/crates/tauri-cli/schema.json",
  "productName": "Floaty",
  "version": "0.1.1",
  "identifier": "com.floaty.notes",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "label": "panel",
        "title": "Floaty",
        "url": "panel.html",
        "width": 300,
        "height": 450,
        "minWidth": 300,
        "minHeight": 450,
        "resizable": true,
        "visible": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "decorations": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "tooltip": "Floaty"
    }
  }
}
